# =============================================================
# Turtle Talk — environment variables
# Copy to .env.local and fill in values. NEXT_PUBLIC_* = client-exposed.
# =============================================================

# -------------------------------------------------------------
# App
# -------------------------------------------------------------
# Optional. Used for OG metadata and sitemap. Also used to derive auth cookie
# storage key (sb-<hostname>-auth) so localhost and production use separate
# Supabase auth sessions when sharing the same project.
NEXT_PUBLIC_APP_URL=https://turtletalk.io
# Optional. Override auth cookie/storage key (e.g. sb-dev-auth, sb-prod-auth).
# When unset, derived from NEXT_PUBLIC_APP_URL hostname.
# NEXT_PUBLIC_AUTH_STORAGE_KEY=

# Demo mode
# -------------------------------------------------------------
# /demo is enabled by default when missing.
# Set to 'false' to disable demo mode and redirect /demo to /.
# DEMO_MODE_ENABLED=false

# Demo step skipping
# -------------------------------------------------------------
# Comma-separated list of child-flow demo steps to skip entirely.
# Valid step names:
#   tattleCard           — tattle card picker
#   childWarmupName      — child name / age / fun facts form
#   childCourageConversation — live voice chat with Tammy
#   missionsPick         — choose a brave mission
#   missionDo            — mark mission complete / dismiss
#   wish                 — make-a-wish screen
#   survey               — quick feedback & QR code for parent
#
# Example: NEXT_PUBLIC_DEMO_SKIP_STEPS=tattleCard,wish
# NEXT_PUBLIC_DEMO_SKIP_STEPS=

# -------------------------------------------------------------
# Voice / Talk (pick one)
# -------------------------------------------------------------
# native (default) | livekit | vapi | gemini-live | openai-realtime
NEXT_PUBLIC_VOICE_PROVIDER=native

# When NEXT_PUBLIC_VOICE_PROVIDER=livekit (required for /api/livekit/token)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# -------------------------------------------------------------
# Speech — native pipeline (when VOICE_PROVIDER=native)
# -------------------------------------------------------------
# Providers: anthropic | openai | gemini (chat); openai | gemini (STT); elevenlabs | gemini (TTS)
SPEECH_CHAT_PROVIDER=anthropic
SPEECH_STT_PROVIDER=openai
SPEECH_TTS_PROVIDER=elevenlabs

# API keys — set the ones you use
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=sk_...
GEMINI_API_KEY=AIza...

# -------------------------------------------------------------
# Database
# -------------------------------------------------------------
# localStorage (default) | supabase | convex. Parent dashboard always uses Supabase.
NEXT_PUBLIC_DB_PROVIDER=localStorage

# When using Supabase (Auth, parent dashboard, or DB_PROVIDER=supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CHILD_SESSION_SECRET=

# When NEXT_PUBLIC_DB_PROVIDER=convex (run npx convex dev first)
# NEXT_PUBLIC_CONVEX_URL=

# -------------------------------------------------------------
# SMS (optional)
# -------------------------------------------------------------
SMS_PROVIDER=plivo
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=

# -------------------------------------------------------------
# Development / optional
# -------------------------------------------------------------
# HEALTHCHECK_VERBOSE=true
# ENABLE_SESSION_LOGGING=true
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=turtle-talk

# -------------------------------------------------------------
# Optional: other voice providers
# -------------------------------------------------------------
# Vapi: NEXT_PUBLIC_VAPI_PUBLIC_KEY, NEXT_PUBLIC_VAPI_ASSISTANT_ID, NEXT_PUBLIC_CUSTOM_LLM_URL
# Gemini Live: uses GEMINI_API_KEY for /api/gemini-live/token
