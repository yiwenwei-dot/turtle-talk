# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
livekit-agent/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug / local agent NDJSON (may contain user text, session ids, telemetry)
debug-*.log
.cursor/debug-*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# git worktrees
.worktrees/

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

.vercel
.env*.local

# logs (runtime + guardrail captures — do not ship)
logs/
!/logs/.gitkeep

# Cursor IDE local (never commit)
.cursor/
.cursorrules